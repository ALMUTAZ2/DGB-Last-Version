rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Global Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Validation Blueprints (Anti-Update-Gap)
    function isValidLetter(data) {
      return data.keys().hasAll(['entity_source', 'letter_number', 'letter_date', 'due_date', 'status'])
        && data.entity_source is string && data.entity_source.size() <= 200
        && data.letter_number is string && data.letter_number.size() <= 100
        && data.letter_date is string && data.letter_date.size() <= 50
        && data.due_date is string && data.due_date.size() <= 50
        && (data.status == 'جديد' || data.status == 'الحاقي' || data.status == 'مغلق')
        && (data.get('priority', 'عالية') == 'عالية' || data.get('priority', 'عالية') == 'متوسطة' || data.get('priority', 'عالية') == 'منخفضة')
        && data.get('category', '') is string && data.get('category', '').size() <= 500
        && data.get('responsible_department', '') is string && data.get('responsible_department', '').size() <= 200
        && data.get('owner', '') is string && data.get('owner', '').size() <= 200
        && data.get('escalation', '') is string && data.get('escalation', '').size() <= 1000
        && data.get('action_taken', '') is string && data.get('action_taken', '').size() <= 1000
        && data.get('notes', '') is string && data.get('notes', '').size() <= 2000
        && data.get('outgoing_letter_number', '') is string && data.get('outgoing_letter_number', '').size() <= 100
        && data.get('outgoing_letter_date', '') is string && data.get('outgoing_letter_date', '').size() <= 50
        && data.get('close_date', '') is string && data.get('close_date', '').size() <= 50
        && data.get('created_at', '') is string && data.get('created_at', '').size() <= 100
        && data.get('updated_at', '') is string && data.get('updated_at', '').size() <= 100;
    }

    function isValidSetting(data) {
      return (data.keys().hasAll(['key', 'value']) 
              && data.key is string && data.key.size() <= 100
              && data.value is string && data.value.size() <= 5000)
             || (data.get('recipient_phone', '') is string && data.get('recipient_phone', '').size() <= 50
              && data.get('phone_number_id', '') is string && data.get('phone_number_id', '').size() <= 100
              && data.get('access_token', '') is string && data.get('access_token', '').size() <= 5000
              && data.get('groq_api_key', '') is string && data.get('groq_api_key', '').size() <= 500
              && data.get('gemini_api_key', '') is string && data.get('gemini_api_key', '').size() <= 500);
    }

    function isValidWhatsAppLog(data) {
      return data.keys().hasAll(['recipient_phone', 'message_content', 'status', 'sent_at'])
        && data.recipient_phone is string && data.recipient_phone.size() <= 50
        && data.message_content is string && data.message_content.size() <= 5000
        && data.status is string && data.status.size() <= 50
        && data.sent_at is string && data.sent_at.size() <= 100
        && (data.get('error_message', null) == null || (data.get('error_message', '') is string && data.get('error_message', '').size() <= 2000));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role'])
        && data.email is string && data.email.size() <= 100
        && (data.role == 'manager' || data.role == 'staff')
        && data.get('name', '') is string && data.get('name', '').size() <= 100;
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['id', 'type', 'actionType', 'topic', 'date', 'time', 'location', 'status'])
        && (data.id is int || data.id is string)
        && data.type == 'meeting'
        && data.actionType is string && data.actionType.size() <= 100
        && data.topic is string && data.topic.size() <= 500
        && data.date is string && data.date.size() <= 50
        && data.time is string && data.time.size() <= 50
        && data.location is string && data.location.size() <= 200
        && data.status is string && data.status.size() <= 100
        && data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 100;
    }

    // Collection Matches
    match /letters/{letterId} {
      allow read: if true;
      allow create: if isValidId(letterId) && isValidLetter(incoming());
      allow update: if isValidId(letterId) && isValidLetter(incoming()) && (
        data.get('created_at', '') == incoming().get('created_at', '')
      );
      allow delete: if isValidId(letterId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isValidId(settingId) && isValidSetting(incoming());
      allow delete: if isValidId(settingId);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isValidId(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isValidUser(incoming());
      allow delete: if isValidId(userId);
    }

    match /whatsapp_logs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) && isValidWhatsAppLog(incoming());
      allow update: if isValidId(logId) && isValidWhatsAppLog(incoming());
      allow delete: if isValidId(logId);
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if isValidId(reportId) && isValidMeeting(incoming());
      allow update: if isValidId(reportId) && isValidMeeting(incoming()) && (
        data.get('createdAt', '') == incoming().get('createdAt', '')
      );
      allow delete: if isValidId(reportId);
    }
  }
}
